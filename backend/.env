DATABASE_URL=sqlite+aiosqlite:///./antigravity.db
LLM_API_KEY=
LLM_MODEL=gpt-4
LLM_PROVIDER=openai
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_ENABLED=true
OLLAMA_TIMEOUT=30

# Routing: auto | ollama_only | cloud_only | fallback_only
LLM_ROUTING_MODE=auto

# Privacy Mode — forces local Ollama, disables all cloud calls
PRIVACY_MODE=false

# Response Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=256
CACHE_TTL_SECONDS=3600
